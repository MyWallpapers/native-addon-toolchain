{
  "runtime": "canvas-v1",
  "name": "Native hook build smoke",
  "description": "Exercises the official Windhawk build and bundle pipeline.",
  "version": "0.0.0",
  "entry": "dist/index.html",
  "thumbnail": "assets/thumbnail.png",
  "deviceSettingsVersion": "1",
  "settings": [
    {
      "id": "revision",
      "type": "number",
      "label": "Revision",
      "scope": "device",
      "default": 0,
      "min": 0,
      "max": 1000,
      "step": 1
    }
  ],
  "native": {
    "hooks": [
      {
        "id": "build-smoke",
        "runtime": "windhawk-v1",
        "source": "native/hooks/build-smoke.wh.cpp",
        "surface": "windows-shell-v1"
      }
    ]
  },
  "ui": { "pointerEvents": "none" }
}
